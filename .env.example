# Copy to .env.local (gitignored) and fill in real values to run examples/dev-smoke.html.
# Both values are required by window.Lydian.init().

# A merchant publishable key for the target environment (dev, for the smoke harness).
VITE_PUBLISHABLE_KEY=

# A WalletConnect v2 project id. WalletConnect is dormant (QR-only checkout), but
# init() still requires a non-empty value. Any valid WC project id works.
VITE_WALLET_CONNECT_PROJECT_ID=
